   auto pose = costmap_client_.getRobotPose();
   // get frontiers sorted according to cost
   auto frontiers = search_.searchFrom(pose.position);
+  if (prefer_minimum_turn_) {
+    const auto& q = pose.orientation;
+    const double robot_yaw = std::atan2(
+        2.0 * (q.w * q.z + q.x * q.y),
+        1.0 - 2.0 * (q.y * q.y + q.z * q.z));
+    const auto turn_angle = [&pose, robot_yaw](
+                                const frontier_exploration::Frontier& frontier) {
+      const double bearing = std::atan2(frontier.centroid.y - pose.position.y,
+                                        frontier.centroid.x - pose.position.x);
+      return std::abs(std::atan2(std::sin(bearing - robot_yaw),
+                                std::cos(bearing - robot_yaw)));
+    };
+    std::stable_sort(frontiers.begin(), frontiers.end(),
+                     [&turn_angle](const auto& lhs, const auto& rhs) {
+      const double lhs_turn = turn_angle(lhs);
+      const double rhs_turn = turn_angle(rhs);
+      if (std::abs(lhs_turn - rhs_turn) > 1e-6) {
+        return lhs_turn < rhs_turn;
+      }
+      return lhs.cost < rhs.cost;
+    });
+  }
   RCLCPP_DEBUG(logger_, "found %lu frontiers", frontiers.size());
   for (size_t i = 0; i < frontiers.size(); ++i) {
