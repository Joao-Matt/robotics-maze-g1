.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/

# Generated run artifacts are intentionally excluded from Git.
runs/*
!runs/.gitkeep

# Locally fetched third-party policy repos are intentionally not vendored.
third_party/

# Local editor/system files.
.DS_Store
.idea/
.vscode/
.tmp/

# Machine-local storage policy (see .env.storage.example).
.env.storage
